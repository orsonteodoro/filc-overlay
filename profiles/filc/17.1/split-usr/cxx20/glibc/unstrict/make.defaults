# Fil-C unstrict profile: split-usr / cxx20 / glibc
CC="/opt/fil/bin/filcc"
CXX="/opt/fil/bin/fil++"

# Default to C++20
CXXFLAGS="${CXXFLAGS} -std=c++20"

# Hardening flags enabled across the entire overlay
CFLAGS="${CFLAGS} -fPIC -fstack-protector-strong"
CXXFLAGS="${CXXFLAGS} -fPIC -fstack-protector-strong"
